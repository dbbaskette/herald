# Smoke harness configuration. Copy to .env.smoke and fill in the values
# you want to override. .env.smoke is gitignored.
#
# Values in .env.smoke take precedence over the repo-level .env.

# ── herald-bot endpoint ─────────────────────────────────────────────────
# Where the smoke harness reaches the bot.
HERALD_BOT_URL=http://127.0.0.1:8081

# Max seconds to wait for a /api/chat reply.
HERALD_SMOKE_TIMEOUT=15

# Max seconds to wait for the bot to come up during T0-01 (boot clean).
# Default 90s — Maven-driven startup is slow. Lower if you switch to
# java -jar based startup.
HERALD_SMOKE_BOOT_TIMEOUT=90

# ── Telegram path tests (T0-09, T0-11) ──────────────────────────────────
# Optional but recommended. Without these, Telegram-path tests are skipped.
# Use a dedicated test bot — don't reuse your production bot — to keep
# smoke chatter out of your real chat history.

# Token from BotFather for the test bot.
HERALD_SMOKE_TG_BOT_TOKEN=

# Your chat id with the test bot. Find via:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
HERALD_SMOKE_TG_CHAT_ID=
