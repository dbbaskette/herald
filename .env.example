# Herald — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then either source it manually or use the run script:
#   source .env && make dev
#   ./run.sh

# ── Required ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HERALD_TELEGRAM_BOT_TOKEN=
HERALD_TELEGRAM_ALLOWED_CHAT_ID=

# ── Optional: Additional AI Providers ────────────────────────────────
# Provide API keys for any providers you want available.
# Only providers with keys will be enabled.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=ollama

# ── Optional: Google Workspace CLI (gws) ─────────────────────────────
# OAuth client credentials from Google Cloud Console (APIs & Services → Credentials → OAuth 2.0 Client ID)
# See docs/gws-setup.md for full setup instructions.
# GOOGLE_WORKSPACE_CLI_CLIENT_ID=
# GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=

# ── Optional: Model Selection ────────────────────────────────────────
# Choose which model to use for each role. Mix providers freely —
# just make sure you've provided the API key above for each provider you reference.
#
# HERALD_DEFAULT_PROVIDER=anthropic               # Boot-time provider: anthropic, openai, ollama, gemini
# HERALD_MODEL_DEFAULT=claude-sonnet-4-5         # Main agent model (for the default provider)
# HERALD_MODEL_HAIKU=claude-haiku-4-5            # Fast/cheap subagent tier
# HERALD_MODEL_SONNET=claude-sonnet-4-5          # Mid-tier subagent
# HERALD_MODEL_OPUS=claude-opus-4-5              # High-capability subagent tier
# HERALD_MODEL_OPENAI=gpt-4o                     # OpenAI subagent tier
# HERALD_MODEL_OLLAMA=llama3.2                   # Ollama (local) subagent tier
# HERALD_MODEL_GEMINI=gemini-2.5-flash           # Gemini subagent tier

# ── Optional: Agent Behavior ─────────────────────────────────────────
# HERALD_CRON_TIMEZONE=America/New_York
# HERALD_AGENT_PERSONA=
# HERALD_AGENT_SYSTEM_PROMPT_EXTRA=
# HERALD_AGENT_CONTEXT_FILE=~/.herald/CONTEXT.md
# HERALD_AGENT_MAX_CONTEXT_TOKENS=200000

# ── Optional: Web & Weather ──────────────────────────────────────────
# HERALD_WEB_SEARCH_API_KEY=
# HERALD_WEATHER_LOCATION=

# ── Optional: Server ─────────────────────────────────────────────────
# HERALD_SERVER_PORT=8080

# ── Optional: UI Paths ───────────────────────────────────────────────
# HERALD_SKILLS_PATH=~/.herald/skills
# HERALD_BUNDLED_SKILLS_PATH=/path/to/herald/skills
