# Herald — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then either source it manually or use the run script:
#   source .env && make dev
#   ./run.sh

# ── Required ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
HERALD_TELEGRAM_BOT_TOKEN=
HERALD_TELEGRAM_ALLOWED_CHAT_ID=

# ── Optional: Additional AI Providers ────────────────────────────────
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=ollama

# ── Optional: Google Workspace (MCP servers) ─────────────────────────
# GCAL_MCP_URL=
# GMAIL_MCP_URL=

# ── Optional: Agent Behavior ─────────────────────────────────────────
# HERALD_CRON_TIMEZONE=America/New_York
# HERALD_AGENT_PERSONA=
# HERALD_AGENT_SYSTEM_PROMPT_EXTRA=
# HERALD_AGENT_CONTEXT_FILE=~/.herald/CONTEXT.md
# HERALD_AGENT_MAX_CONTEXT_TOKENS=200000

# ── Optional: Web & Weather ──────────────────────────────────────────
# HERALD_WEB_SEARCH_API_KEY=
# HERALD_WEATHER_LOCATION=

# ── Optional: Server ─────────────────────────────────────────────────
# HERALD_SERVER_PORT=8080

# ── Optional: UI Paths ───────────────────────────────────────────────
# HERALD_SKILLS_PATH=~/.herald/skills
# HERALD_BUNDLED_SKILLS_PATH=/path/to/herald/.claude/skills
